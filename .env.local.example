# The Flask backend URL for proxying API requests during local dev or Vercel.
API_PROXY_TARGET=https://inbox-manager-v2-rebuild-production.up.railway.app

# Backend route prefix. The rebuild backend uses /api/review.
# The audit monolith uses /review/api.
API_PROXY_PATH=/api/review

# Optional: override the API base URL in the browser (defaults to /api/review).
# Useful for pointing directly at a remote backend without proxy.
# NEXT_PUBLIC_API_BASE_URL=/api/review
